generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  passwordRaw    String?  // Store temporary password for display
  role           String   // "ADMIN" | "STUDENT"
  batchId        String?
  courseDuration Int?
  phoneNumber    String?
  status         String?  @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  batchId     String
  dueDate     DateTime?
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  batchId   String   @default("All Batches")
  createdAt DateTime @default(now())
}
model Payment {
  id           String   @id @default(uuid())
  studentName String
  email        String
  batch        String
  academicYear Int
  amount       Float
  paidDate     DateTime
  status       String   @default("Paid")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Batch {
  id          Int      @id @default(autoincrement())
  name        String
  instructor  String?
  description String?
  startDate   DateTime
  endDate     DateTime?
  schedule    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
